# Copy this file to .env.local (note the leading dot). Next.js does not load env.local.
#
# Admin Configuration
ADMIN_USERNAME=admin
# Set your admin password here. Default is 'admin123'
ADMIN_PASSWORD=admin123
# Secret for signing admin JWT cookies (min 16 characters). Required for production.
ADMIN_JWT_SECRET=change-this-to-a-long-random-string-at-least-16-chars

# Optional: Customize session duration (in milliseconds, default is 24 hours)
# SESSION_DURATION=86400000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cloudinary (admin photo / community logo uploads)
# Copy the full line from Cloudinary → Dashboard → API Keys → "API environment variable".
# The host after @ is your cloud name (e.g. dxxxxxxx), not the "Key name" label.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Or set these three (same values as on that page):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional: Supabase Storage bucket names (legacy; uploads use Cloudinary when configured above).
# NEXT_PUBLIC_SUPABASE_RESEARCHERS_BUCKET=researchers
# NEXT_PUBLIC_SUPABASE_COMMUNITIES_BUCKET=communities
